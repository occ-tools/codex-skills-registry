{
  "name": "@wangjiehu/codex-skills-registry",
  "version": "1.0.2",
  "description": "Validate, index, and test Codex Skills, plugin manifests, and MCP server configs for open-source maintainer workflows.",
  "type": "module",
  "license": "MIT",
  "author": "wangjiehu",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wangjiehu/codex-skills-registry.git"
  },
  "bugs": {
    "url": "https://github.com/wangjiehu/codex-skills-registry/issues"
  },
  "homepage": "https://github.com/wangjiehu/codex-skills-registry#readme",
  "keywords": [
    "codex",
    "openai",
    "skills",
    "mcp",
    "plugins",
    "github-actions",
    "sarif",
    "json-schema",
    "oss",
    "maintainer-tools"
  ],
  "sideEffects": false,
  "packageManager": "npm@11.14.0",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./cli": {
      "types": "./dist/cli.d.ts",
      "import": "./dist/cli.js"
    }
  },
  "typesVersions": {
    "*": {
      "cli": [
        "./dist/cli.d.ts"
      ]
    }
  },
  "bin": {
    "codex-skills": "dist/cli.js"
  },
  "files": [
    "dist",
    "examples",
    "demo",
    "docs",
    "action.yml",
    ".codex-skills-registry.yaml",
    "README.md",
    "CHANGELOG.md",
    "CONTRIBUTING.md",
    "CODE_OF_CONDUCT.md",
    "SECURITY.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/cli.ts",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "lint": "biome lint .",
    "test": "vitest run",
    "prepack": "npm run build",
    "prepublishOnly": "npm run release:check",
    "pack:check": "npm pack --dry-run",
    "security:audit": "npm audit --audit-level=moderate",
    "market:check": "npm run release:check && npm run security:audit",
    "release:check": "npm run validate && npm run pack:check",
    "validate": "npm run lint && npm run format:check && npm run build && npm test"
  },
  "dependencies": {
    "commander": "^14.0.2",
    "smol-toml": "^1.4.2",
    "yaml": "^2.8.1",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@types/node": "^24.10.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.14"
  },
  "engines": {
    "node": ">=20",
    "npm": ">=10"
  }
}
