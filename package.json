{
  "name": "codex-skills-registry",
  "version": "0.1.0",
  "description": "Validate, index, and test Codex Skills, plugin manifests, and MCP server configs for open-source maintainer workflows.",
  "type": "module",
  "license": "MIT",
  "author": "codex-skills-registry contributors",
  "keywords": [
    "codex",
    "openai",
    "skills",
    "mcp",
    "plugins",
    "github-actions",
    "oss",
    "maintainer-tools"
  ],
  "sideEffects": false,
  "packageManager": "npm@11.14.0",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./cli": {
      "types": "./dist/cli.d.ts",
      "import": "./dist/cli.js"
    }
  },
  "bin": {
    "codex-skills": "./dist/cli.js"
  },
  "files": [
    "dist",
    "examples",
    "action.yml",
    ".codex-skills-registry.yaml",
    "README.md",
    "CHANGELOG.md",
    "CONTRIBUTING.md",
    "SECURITY.md",
    "ROADMAP.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/cli.ts",
    "test": "vitest run",
    "prepack": "npm run build",
    "pack:check": "npm pack --dry-run",
    "validate": "npm run build && npm test"
  },
  "dependencies": {
    "commander": "^14.0.2",
    "smol-toml": "^1.4.2",
    "yaml": "^2.8.1",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.14"
  },
  "engines": {
    "node": ">=20"
  }
}
